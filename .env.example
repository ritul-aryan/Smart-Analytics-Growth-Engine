# ============================================================================
# MAE — Environment Configuration Template
# ============================================================================
#
# Copy this file to .env and fill in the required values.
#
#   cp .env.example .env
#
# Lines marked [REQUIRED] must be set before starting the server.
# Lines marked [OPTIONAL] have safe defaults for local development.
# Lines marked [CLOUD ONLY] are unused in the default local-dev stack.
#
# The backend reads this file via pydantic-settings (backend/config.py).
# The frontend reads VITE_* variables at build time (vite.config.ts).
# ============================================================================


# ----------------------------------------------------------------------------
# LLM Provider
# ----------------------------------------------------------------------------

# Active LLM provider. Switchable from the UI per-session.
# Choices: gemini-2.0-flash | gemini-1.5-flash | ollama
LLM_PROVIDER=gemini-2.0-flash

# [REQUIRED for gemini-*] Google AI Studio API key.
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# [OPTIONAL] Base URL of a running Ollama server.
OLLAMA_BASE_URL=http://localhost:11434

# [OPTIONAL] Ollama model used for routing / header normalisation.
OLLAMA_ROUTER_MODEL=qwen2.5-coder:7b

# [OPTIONAL] Ollama model used for narrative generation and chart specs.
OLLAMA_STORYTELLER_MODEL=llama3.1:8b


# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------

# Active database backend.
# Choices: sqlite (local dev) | postgres (cloud / production)
DB_BACKEND=sqlite

# [OPTIONAL] Filesystem path for the SQLite database file.
# The directory is created automatically if it does not exist.
SQLITE_PATH=./data/mae.db

# [CLOUD ONLY] Async SQLAlchemy URL used when DB_BACKEND=postgres.
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/mae


# ----------------------------------------------------------------------------
# Task Queue
# ----------------------------------------------------------------------------

# Active task queue backend.
# Choices: background (FastAPI BackgroundTasks — local) | arq (Redis — cloud)
TASK_BACKEND=background

# [CLOUD ONLY] Redis connection URL. Required when TASK_BACKEND=arq.
REDIS_URL=redis://localhost:6379


# ----------------------------------------------------------------------------
# File Storage
# ----------------------------------------------------------------------------

# Active storage backend.
# Choices: local (disk) | s3 (AWS S3 — cloud)
STORAGE_BACKEND=local

# [OPTIONAL] Local directory for raw uploaded files.
LOCAL_UPLOAD_DIR=./data/uploads

# [OPTIONAL] Local directory for cleaned / engineered CSV outputs.
LOCAL_PROCESSED_DIR=./data/processed

# [CLOUD ONLY] AWS S3 bucket name. Required when STORAGE_BACKEND=s3.
AWS_BUCKET_NAME=

# [CLOUD ONLY] AWS access key ID. Required when STORAGE_BACKEND=s3.
AWS_ACCESS_KEY_ID=

# [CLOUD ONLY] AWS secret access key. Required when STORAGE_BACKEND=s3.
AWS_SECRET_ACCESS_KEY=


# ----------------------------------------------------------------------------
# Code Sandbox
# ----------------------------------------------------------------------------

# Active code execution sandbox.
# Choices: restricted (AST whitelist + thread timeout — local)
#          docker (isolated container — cloud / higher security)
SANDBOX_BACKEND=restricted


# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------

# Runtime environment. Controls debug behaviour and log verbosity.
# Choices: development | production
APP_ENV=development

# Python logging level for the backend application.
# Choices: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Maximum permitted upload file size in megabytes (1–500).
MAX_UPLOAD_SIZE_MB=50

# Row count above which the orchestrator emits a soft warning.
# Not a hard cut-off — processing continues regardless.
ROW_LIMIT_SOFT_WARNING=50000


# ----------------------------------------------------------------------------
# Frontend (Vite build-time variables)
# ----------------------------------------------------------------------------

# Backend API base URL consumed by the Vite dev proxy and production builds.
# In development the Vite proxy forwards /api/* to this address automatically.
# In production set this to your deployed backend URL.
VITE_API_BASE_URL=http://localhost:8000
